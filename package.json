    "svelte": "^4.2.18"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^3.1.2",
    "@types/node": "^22.5.0",
    "svelte-check": "^3.8.6",
    "tslib": "^2.6.3",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  }
}
